NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ihahiro
DB_SYNCHRONIZE=false

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# CORS
WEB_APP_ORIGIN=http://localhost:3000

# Media storage driver: 'local' (disk) or 'cloudinary' (Cloudinary + S3 fallback)
MEDIA_DRIVER=local
MEDIA_LOCAL_DIR=uploads
MEDIA_PUBLIC_BASE_URL=http://localhost:4000/uploads

# Cloudinary (primary) with S3 fallback — fill these when MEDIA_DRIVER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: CDN/custom domain in front of the bucket, e.g. https://cdn.ihahiro.com
AWS_S3_PUBLIC_BASE_URL=
